{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Elin mod localization.json schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "general",
    "format"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "スキーマのURI"
    },
    "general": {
      "type": "object",
      "additionalProperties": false,
      "description": "単独で使用される文字列",
      "patternProperties": {
        "^[A-Z][a-z0-9_][a-zA-Z0-9_]*$": {
          "type": "object",
          "additionalProperties": false,
          "description": "key",
          "required": [
            "JP",
            "EN"
          ],
          "properties": {
            "JP": {
              "type": "string",
              "description": "日本語翻訳"
            },
            "EN": {
              "type": "string",
              "description": "英語翻訳"
            },
            "CN": {
              "type": "string",
              "description": "中国語翻訳"
            },
            "ZHTW": {
              "type": "string",
              "description": "繁体字中国語翻訳"
            },
            "KR": {
              "type": "string",
              "description": "韓国語翻訳"
            }
          }
        }
      }
    },
    "format": {
      "type": "object",
      "description": "書式変換元文字列",
      "additionalProperties": false,
      "patternProperties": {
        "^[A-Z][a-z0-9_][a-zA-Z0-9_]*$": {
          "type": "object",
          "additionalProperties": false,
          "description": "key",
          "required": [
            "JP",
            "EN",
            "parameters"
          ],
          "properties": {
            "JP": {
              "type": "string",
              "description": "日本語翻訳"
            },
            "EN": {
              "type": "string",
              "description": "英語翻訳"
            },
            "CN": {
              "type": "string",
              "description": "中国語翻訳"
            },
            "ZHTW": {
              "type": "string",
              "description": "繁体字中国語翻訳"
            },
            "KR": {
              "type": "string",
              "description": "韓国語翻訳"
            },
            "parameters": {
              "type": "object",
              "description": "パラメータ名",
              "additionalProperties": false,
              "patternProperties": {
                "^[A-Z][A-Z0-9_]*$": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "type"
                  ],
                  "properties": {
                    "type": {
                      "type": "string",
                      "description": "パラメータの型(C#のプリミティブ型)",
                      "enum": [
                        "int",
                        "float",
                        "double",
                        "string"
                      ]
                    },
                    "format": {
                      "type": "string",
                      "description": "type.ToString() の書式指定文字列"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
